{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "api/index.py" },
    { "src": "/style.css", "dest": "api/index.py" },
    { "src": "/script.js", "dest": "api/index.py" },
    { "src": "/", "dest": "api/index.py" }
  ]
}
